[Unit]
Description=FastAPI MySQL Products API
After=network.target mysql.service
Wants=mysql.service

[Service]
User=aakash
Group=aakash
WorkingDirectory=/home/aakash/Desktop/DevOpsBootcamp/week2/day4/fastapi-mysql-api

# Path to your venv uvicorn
ExecStart=/home/aakash/Desktop/DevOpsBootcamp/week2/day4/fastapi-mysql-api/venv/bin/uvicorn main:app \
    --host 0.0.0.0 \
    --port 8000 \
    --workers 4 \
    --log-level info

EnvironmentFile=/home/aakash/Desktop/DevOpsBootcamp/week2/day4/fastapi-mysql-api/.env

Environment="PYTHONUNBUFFERED=1"
Restart=always
RestartSec=10

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target