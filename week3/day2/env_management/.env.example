# ─── Application ────────────────────────────────────────────────
# Copy this file to .env and fill in all values before running.
APP_NAME=
APP_ENV=
APP_DEBUG=
APP_PORT=

# ─── Database (PostgreSQL) ───────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# ─── Redis ──────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Exposed host ports ─────────────────────────────────────────
API_PORT=
REDIS_EXPOSED_PORT=
