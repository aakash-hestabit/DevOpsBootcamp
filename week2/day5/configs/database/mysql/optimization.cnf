# Description: MySQL read-optimized configuration for Stack 3
# Purpose: Tune MySQL for read-heavy workloads with FastAPI async connections

[mysqld]
# Basic Settings
server-id = 1
bind-address = 0.0.0.0
port = 3306
datadir = /var/lib/mysql
socket = /var/run/mysqld/mysqld.sock
pid-file = /var/run/mysqld/mysqld.pid

# Character Set
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# Read Optimization - InnoDB Buffer Pool
# Set to 70-80% of available RAM for dedicated DB server
# For development, use 256M-512M
innodb_buffer_pool_size = 512M
innodb_buffer_pool_instances = 4

# Read Performance - InnoDB Settings
innodb_read_io_threads = 8
innodb_write_io_threads = 4
innodb_io_capacity = 2000
innodb_io_capacity_max = 4000

# Buffer Pool Optimization for Reads
innodb_old_blocks_time = 1000
innodb_old_blocks_pct = 37
innodb_random_read_ahead = ON

# Query Cache (MySQL 5.7 - deprecated in 8.0)
# For MySQL 8.0, use application-level caching (Redis, Memcached)
# query_cache_type = 1
# query_cache_size = 128M
# query_cache_limit = 2M

# Connection Pool Settings
max_connections = 200
max_connect_errors = 100000
wait_timeout = 600
interactive_timeout = 600
connect_timeout = 10

# Thread Pool (for connection handling)
thread_cache_size = 50
thread_stack = 256K

# Table Cache
table_open_cache = 4000
table_definition_cache = 2000
table_open_cache_instances = 8

# Temporary Tables
tmp_table_size = 64M
max_heap_table_size = 64M

# Join and Sort Buffer (per-connection)
join_buffer_size = 2M
sort_buffer_size = 2M
read_buffer_size = 1M
read_rnd_buffer_size = 2M

# Log Settings
log_error = /var/log/mysql/error.log
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow-query.log
long_query_time = 2
log_queries_not_using_indexes = 1

# Binary Logging (for replication, if needed)
# log_bin = /var/log/mysql/mysql-bin.log
# binlog_format = ROW
# expire_logs_days = 7

# InnoDB Flush Settings
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT

# InnoDB Log Settings
innodb_log_file_size = 256M
innodb_log_buffer_size = 16M

# Performance Schema
performance_schema = ON
performance_schema_max_table_instances = 1000

# Skip DNS Resolution for faster connections
skip-name-resolve

# Disable unnecessary features for read workload
skip-external-locking

[mysql]
default-character-set = utf8mb4

[client]
default-character-set = utf8mb4
socket = /var/run/mysqld/mysqld.sock
